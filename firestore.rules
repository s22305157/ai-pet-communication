rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 使用者資料規則 (Users 集合)
    match /Users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId 
                    && request.resource.data.points == 1; // 初始點數鎖定為 1
      
       // 安全規則覆核：
       // 允許更新：限本人，且確保點數邏輯與 UID 不變
       allow update: if request.auth != null && request.auth.uid == userId
                     && (
                       // 1. 點數只能減少 (或不變)，且不得低於 0
                       (request.resource.data.points <= resource.data.points && request.resource.data.points >= 0)
                       &&
                       // 2. 確保 uid 欄位不可變動
                       (request.resource.data.uid == resource.data.uid)
                     );
       
       // 允許刪除：本人帳號
       allow delete: if request.auth != null && request.auth.uid == userId;

     }
    
    // 寵物資料規則 (pets 集合)
    match /pets/{petId} {
      allow read, update, delete: if request.auth != null && resource.data.owner_id == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.owner_id == request.auth.uid;
      
      // 溝通紀錄規則 (readings 子集合)
      match /readings/{readingId} {
        // 確保只有寵物擁有人可以存取紀錄
        allow read, write: if request.auth != null 
          && get(/databases/$(database)/documents/pets/$(petId)).data.owner_id == request.auth.uid;
      }
    }
    
    // 預設規則：拒絕所有其他存取
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
